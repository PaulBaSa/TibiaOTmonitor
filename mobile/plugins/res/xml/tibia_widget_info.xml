<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget metadata.
  minWidth="250dp"  → roughly 4 grid cells wide
  minHeight="160dp" → roughly 3 grid cells tall
  updatePeriodMillis="1800000" → system-triggered refresh every 30 min
    (Android enforces a 30-min minimum; use the ↻ button for instant updates)
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="160dp"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/tibia_widget_layout"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />

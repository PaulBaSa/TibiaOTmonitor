<?xml version="1.0" encoding="utf-8"?>
<!--
  4 × 2 arc-style home-screen widget.
  Inspired by Samsung's circular arc battery widget.

  Each ProgressBar uses style="Widget.ProgressBar.Horizontal" which sets
  indeterminateOnly="false" — the only reliable way to keep deterministic
  mode in the launcher process (android:indeterminate="false" alone is
  ignored by the default Widget.ProgressBar theme there).
  maxHeight="20dip" from that style is irrelevant: the 64dp FrameLayout
  parent gives EXACTLY constraints so resolveSizeAndState always returns 64dp.

  Layout:
    Row 0 (header): ● status · players · ↻
    Row 1 (arcs):  [CPU arc]  [RAM arc]  [DISK arc]  [PING arc]
                     67%        43%         82%         24ms
    Footer: timestamp
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:paddingTop="4dp"
    android:paddingBottom="2dp">

    <!-- ── Header row ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/status_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x25CF;"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:paddingRight="4dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/players_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:paddingRight="4dp" />

        <TextView
            android:id="@+id/refresh_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x21BB;"
            android:textColor="#C4A535"
            android:textSize="24sp" />
    </LinearLayout>

    <!-- ── Arc tiles row ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- CPU arc tile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/arc_cpu"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@android:color/transparent"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/ring_progress" />

                <TextView
                    android:id="@+id/arc_cpu_val"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- RAM arc tile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/arc_ram"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@android:color/transparent"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/ring_progress" />

                <TextView
                    android:id="@+id/arc_ram_val"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAM"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- DISK arc tile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/arc_disk"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@android:color/transparent"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/ring_progress" />

                <TextView
                    android:id="@+id/arc_disk_val"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISK"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- PING arc tile — max=200ms fills the ring -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/arc_ping"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:indeterminateDrawable="@android:color/transparent"
                    android:max="200"
                    android:progress="0"
                    android:progressDrawable="@drawable/ring_progress" />

                <TextView
                    android:id="@+id/arc_ping_val"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#4CAF50"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PING"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Footer: timestamp ──────────────────────────────────────── -->
    <TextView
        android:id="@+id/last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#444444"
        android:textSize="9sp"
        android:gravity="end" />

</LinearLayout>
